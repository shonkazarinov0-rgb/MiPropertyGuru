{
  "expo": {
    "name": "MiPropertyGuru",
    "slug": "mipropertyguru",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mipropertyguru",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mipropertyguru.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Find contractors near your location",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Share your location with clients to get more jobs",
        "NSCameraUsageDescription": "Take photos of your completed work",
        "NSPhotoLibraryUsageDescription": "Upload photos to your portfolio"
      }
    },
    "android": {
      "package": "com.mipropertyguru.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FF9500"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FF9500"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Find contractors near your location",
          "locationAlwaysAndWhenInUsePermission": "Share your location with clients to get more jobs"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#FF9500"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "mipropertyguru"
      },
      "backendUrl": "https://mipropertyguru-production.up.railway.app"
    }
  }
}
