{
  "expo": {
    "name": "MiPropertyGuru",
    "slug": "mipropertyguru",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mipropertyguru",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mipropertyguru.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Find contractors near your location",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Share your location with clients to get more jobs",
        "NSCameraUsageDescription": "Take photos of your completed work",
        "NSPhotoLibraryUsageDescription": "Upload photos to your portfolio",
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "package": "com.mipropertyguru.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FF9500"
      },
      "edgeToEdgeEnabled": true,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FF9500"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Find contractors near your location",
          "locationAlwaysAndWhenInUsePermission": "Share your location with clients to get more jobs"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#FF9500",
          "defaultChannel": "default",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "4a55a2dd-de98-4ae5-9afb-a1293b4ebc76"
      },
      "backendUrl": "https://mipropertyguru-production.up.railway.app",
      "router": {}
    },
    "owner": "shonkazarinov0"
  }
}
