        "https://images.pexels.com/photos/16552855/pexels-photo-16552855.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
        "https://images.pexels.com/photos/8960995/pexels-photo-8960995.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940"
      ],
      "work_portfolio": [
        "https://images.unsplash.com/photo-1772475329901-58f77a9625ab?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NjAzMzJ8MHwxfHNlYXJjaHw0fHxtb2Rlcm4lMjBob3VzZSUyMGludGVyaW9yJTIwcmVub3ZhdGlvbnxlbnwwfHx8fDE3NzM4NDQzOTh8MA&ixlib=rb-4.1.0&q=85",
        "https://images.unsplash.com/photo-1769738204142-35ce7b6ea0e9?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NjAzMzJ8MHwxfHNlYXJjaHwxfHxtb2Rlcm4lMjBob3VzZSUyMGludGVyaW9yJTIwcmVub3ZhdGlvbnxlbnwwfHx8fDE3NzM4NDQzOTh8MA&ixlib=rb-4.1.0&q=85",
        "https://images.unsplash.com/photo-1773101883573-2afcb4c4ff4b?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NjAzMzJ8MHwxfHNlYXJjaHwyfHxtb2Rlcm4lMjBob3VzZSUyMGludGVyaW9yJTIwcmVub3ZhdGlvbnxlbnwwfHx8fDE3NzM4NDQzOTh8MA&ixlib=rb-4.1.0&q=85"
      ],
      "trade_specific": {
        "plumbing": "https://images.pexels.com/photos/7220892/pexels-photo-7220892.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
        "electrical": "https://images.unsplash.com/photo-1758101755915-462eddc23f57?crop=entropy&cs=srgb&fm=jpg&ixid=M3w3NTY2NzR8MHwxfHNlYXJjaHwzfHxlbGVjdHJpY2lhbiUyMHdvcmtpbmclMjBvbiUyMHBhbmVsfGVufDB8fHx8MTc3Mzg0NDM5OXww&ixlib=rb-4.1.0&q=85",
        "blueprints": "https://images.unsplash.com/photo-1772442198624-4fc4d7281e89?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NjA1ODR8MHwxfHNlYXJjaHwxfHxjb25zdHJ1Y3Rpb24lMjBibHVlcHJpbnQlMjBwbGFuc3xlbnwwfHx8fDE3NzM4NDQ0MDB8MA&ixlib=rb-4.1.0&q=85"
      }
    }
  },
  "implementation_rules": {
    "styling": {
      "method": "StyleSheet.create",
      "forbidden": ["inline styles (except dynamic values)", "Tailwind CSS classes"],
      "safe_area": "Must use SafeAreaView from react-native-safe-area-context",
      "keyboard": "Must use KeyboardAvoidingView for all forms"
    },
    "layout": {
      "flex": "Use Flexbox for all layouts",
      "absolute": "Avoid absolute positioning unless for overlays/markers",
      "lists": "Use FlatList for any list > 5 items"
    },
    "accessibility": {
      "touch_targets": "Ensure minimum 44x44px for all interactive elements",
      "contrast": "Ensure text contrast meets WCAG AA standards"
    }
  },
  "universal_guidelines": [
    "Do not use generic 'Inter' font if possible; rely on System font or custom industrial fonts.",
    "Use yellow/orange for Primary Actions only. Secondary actions should be grey/black.",
    "Map View must be the central experience for finding contractors.",
    "Contract generation should be a simple step-by-step wizard.",
    "All interactive elements MUST include a `data-testid` attribute."
  ]
}