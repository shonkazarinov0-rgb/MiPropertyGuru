{
  "metadata": {
    "app_name": "ConstructConnect",
    "version": "1.0.0",
    "framework": "React Native Expo",
    "styling_engine": "StyleSheet.create()",
    "theme_mode": "Light",
    "description": "A professional contractor finder app with live location and AI contract generation."
  },
  "design_system": {
    "palette": {
      "primary": {
        "main": "#FF9500",
        "light": "#FFB700",
        "dark": "#E08600",
        "contrast_text": "#1C1C1E"
      },
      "secondary": {
        "main": "#1C1C1E",
        "light": "#2C2C2E",
        "dark": "#000000",
        "contrast_text": "#FFFFFF"
      },
      "background": {
        "default": "#F2F2F7",
        "paper": "#FFFFFF",
        "overlay": "rgba(0, 0, 0, 0.5)"
      },
      "text": {
        "primary": "#000000",
        "secondary": "#636366",
        "disabled": "#AEAEB2",
        "placeholder": "#C7C7CC"
      },
      "status": {
        "success": "#34C759",
        "error": "#FF3B30",
        "warning": "#FFCC00",
        "info": "#007AFF"
      },
      "border": {
        "default": "#E5E5EA",
        "focus": "#FF9500"
      }
    },
    "typography": {
      "font_family": {
        "headers": "System", 
        "body": "System"
      },
      "scales": {
        "h1": {
          "fontSize": 34,
          "fontWeight": "700",
          "lineHeight": 41,
          "letterSpacing": 0.37
        },
        "h2": {
          "fontSize": 28,
          "fontWeight": "700",
          "lineHeight": 34,
          "letterSpacing": 0.36
        },
        "h3": {
          "fontSize": 22,
          "fontWeight": "600",
          "lineHeight": 28,
          "letterSpacing": 0.35
        },
        "body_large": {
          "fontSize": 17,
          "fontWeight": "400",
          "lineHeight": 22,
          "letterSpacing": -0.41
        },
        "body_regular": {
          "fontSize": 15,
          "fontWeight": "400",
          "lineHeight": 20,
          "letterSpacing": -0.24
        },
        "caption": {
          "fontSize": 12,
          "fontWeight": "500",
          "lineHeight": 16,
          "letterSpacing": 0
        },
        "button": {
          "fontSize": 17,
          "fontWeight": "600",
          "lineHeight": 22,
          "letterSpacing": -0.41
        }
      }
    },
    "spacing": {
      "xs": 4,
      "s": 8,
      "m": 16,
      "l": 24,
      "xl": 32,
      "xxl": 48
    },
    "layout": {
      "radius": {
        "s": 8,
        "m": 12,
        "l": 16,
        "round": 9999
      },
      "screen_padding": 16,
      "min_touch_target": 44
    },
    "shadows": {
      "light": {
        "shadowColor": "#000",
        "shadowOffset": { "width": 0, "height": 1 },
        "shadowOpacity": 0.1,
        "shadowRadius": 2,
        "elevation": 2
      },
      "medium": {
        "shadowColor": "#000",
        "shadowOffset": { "width": 0, "height": 2 },
        "shadowOpacity": 0.15,
        "shadowRadius": 4,
        "elevation": 4
      },
      "heavy": {
        "shadowColor": "#000",
        "shadowOffset": { "width": 0, "height": 4 },
        "shadowOpacity": 0.2,
        "shadowRadius": 8,
        "elevation": 8
      }
    }
  },
  "component_guidelines": {
    "Buttons": {
      "Primary": {
        "backgroundColor": "primary.main",
        "borderRadius": "layout.radius.l",
        "paddingVertical": 14,
        "alignItems": "center",
        "justifyContent": "center",
        "width": "100%",
        "textStyle": {
          "color": "primary.contrast_text",
          "fontSize": 17,
          "fontWeight": "600"
        }
      },
      "Secondary": {
        "backgroundColor": "transparent",
        "borderWidth": 2,
        "borderColor": "primary.main",
        "borderRadius": "layout.radius.l",
        "paddingVertical": 12,
        "alignItems": "center",
        "width": "100%",
        "textStyle": {
          "color": "primary.main",
          "fontSize": 17,
          "fontWeight": "600"
        }
      }
    },
    "Cards": {
      "ContractorProfile": {
        "backgroundColor": "background.paper",
        "borderRadius": "layout.radius.m",
        "padding": "spacing.m",
        "marginBottom": "spacing.m",
        "shadow": "shadows.light"
      }
    },
    "Inputs": {
      "default": {
        "backgroundColor": "#F2F2F7",
        "borderRadius": "layout.radius.s",
        "paddingHorizontal": "spacing.m",
        "paddingVertical": 12,
        "fontSize": 17,
        "color": "text.primary",
        "borderWidth": 1,
        "borderColor": "transparent"
      },
      "focus": {
        "borderColor": "primary.main",
        "backgroundColor": "#FFFFFF"
      }
    }
  },
  "assets": {
    "images": {
      "contractor_avatars": [
